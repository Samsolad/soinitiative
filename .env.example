# Copy values into Vercel → Project Settings → Environment Variables (soinitiative-new)

# Google Apps Script web app URL (Deploy → Web app → copy URL)
SHEET_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Shared secret sent to Apps Script (must match Script Property SHEET_SECRET)
SHEET_SECRET=replace-with-a-long-random-string

# Preview gate password for So Family / So Wedding admin bypass
GATE_PASS=replace-with-a-strong-preview-password
